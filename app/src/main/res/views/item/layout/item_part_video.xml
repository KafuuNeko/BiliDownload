<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="cc.kafuu.bilidownload.feature.viewbinding.viewmodel.activity.VideoDetailsViewModel" />

        <variable
            name="data"
            type="cc.kafuu.bilidownload.common.model.bili.BiliVideoPartModel" />

        <import type="cc.kafuu.bilidownload.common.utils.TimeUtils" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:background="@color/general_item_background_color"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:onClick="@{()->viewModel.onPartSelected(data)}"
        android:onLongClick="@{()->viewModel.onItemLongClick(data)}"
        app:cardCornerRadius="@dimen/card_item_corner_radius"
        app:cardElevation="@dimen/card_item_elevation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="3"
                android:padding="10dp"
                android:text="@{data.name}"
                android:textColor="@color/general_text_color"
                android:textSize="@dimen/size_text_card_content"
                tools:text="@string/app_name" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@{data.remark}"
                android:textColor="@color/general_text_color"
                android:textSize="@dimen/size_text_card_content"
                tools:text="00:03:43" />

            <!-- 字幕下载按钮 -->
            <ImageView
                android:id="@+id/iv_subtitle"
                bindVisible="@{viewModel.subtitleListLiveData != null &amp;&amp; viewModel.subtitleListLiveData.size() > 0 &amp;&amp; viewModel.loadingVideoPartLiveData != data &amp;&amp; viewModel.downloadingSubtitlePartLiveData != data &amp;&amp; !viewModel.multipleSelectModeLiveData}"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/download_subtitle"
                android:onClick="@{()->viewModel.onDownloadSubtitle(data)}"
                android:padding="2dp"
                android:src="@drawable/ic_subtitle"
                tools:src="@drawable/ic_danmaku" />

            <ProgressBar
                style="?android:attr/progressBarStyleSmall"
                bindVisible="@{viewModel.downloadingSubtitlePartLiveData == data}"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="5dp"
                tools:visibility="gone" />

            <ImageView
                android:id="@+id/iv_danmaku"
                bindVisible="@{viewModel.loadingVideoPartLiveData != data &amp;&amp; viewModel.downloadingDanmakuPartLiveData != data &amp;&amp; !viewModel.multipleSelectModeLiveData}"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/download_danmaku"
                android:onClick="@{()->viewModel.onDownloadDanmaku(data)}"
                android:padding="2dp"
                android:src="@drawable/ic_danmaku" />

            <ProgressBar
                style="?android:attr/progressBarStyleSmall"
                bindVisible="@{viewModel.downloadingDanmakuPartLiveData == data}"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="5dp"
                tools:visibility="gone" />

            <ImageView
                bindVisible="@{viewModel.loadingVideoPartLiveData != data &amp;&amp; viewModel.downloadingDanmakuPartLiveData != data &amp;&amp; !viewModel.multipleSelectModeLiveData}"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="10dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_arrow_right" />

            <ImageView
                bindVisible="@{viewModel.loadingVideoPartLiveData != data &amp;&amp; viewModel.downloadingDanmakuPartLiveData != data &amp;&amp; viewModel.multipleSelectModeLiveData}"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="10dp"
                android:importantForAccessibility="no"
                android:src="@{viewModel.multipleSelectItemsLiveData.contains(data)?@drawable/ic_checked:@drawable/ic_uncheck}"
                tools:visibility="gone" />

            <ProgressBar
                style="?android:attr/progressBarStyleSmall"
                bindVisible="@{viewModel.loadingVideoPartLiveData == data}"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="10dp"
                tools:visibility="gone" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>
</layout>